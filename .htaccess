# Public storefront canonical URLs for tulista.cl
#
# This file lets Apache show the store from /pagina while keeping public URLs clean:
#   https://tulista.cl/pagina/index.php  -> https://tulista.cl/
#   https://tulista.cl/pagina/nosotros.php -> https://tulista.cl/nosotros
#   https://tulista.cl/nosotros -> internally serves /pagina/nosotros.php
#   https://tulista.cl/contacto -> internally serves /pagina/contacto.php

Options -MultiViews
DirectoryIndex index.php

<IfModule mod_rewrite.c>
    RewriteEngine On

    # Canonicalize the old store home URL.
    RewriteCond %{THE_REQUEST} \s/+pagina/index\.php[\s?] [NC]
    RewriteRule ^pagina/index\.php$ / [R=301,L]

    # Canonicalize old direct PHP page URLs under /pagina.
    RewriteCond %{THE_REQUEST} \s/+pagina/([^\s?]+)\.php[\s?] [NC]
    RewriteCond %1 !^index$ [NC]
    RewriteRule ^pagina/([^/]+)\.php$ /$1 [R=301,L]

    # Serve the storefront at the domain root when /pagina/index.php exists.
    RewriteCond %{DOCUMENT_ROOT}/pagina/index.php -f
    RewriteRule ^$ /pagina/index.php [L]

    # Keep real files and directories available as-is.
    RewriteCond %{REQUEST_FILENAME} -f [OR]
    RewriteCond %{REQUEST_FILENAME} -d
    RewriteRule ^ - [L]

    # Clean one-segment storefront pages: /nosotros -> /pagina/nosotros.php.
    RewriteCond %{DOCUMENT_ROOT}/pagina/$1.php -f
    RewriteRule ^([A-Za-z0-9_-]+)/?$ /pagina/$1.php [L,QSA]
</IfModule>
